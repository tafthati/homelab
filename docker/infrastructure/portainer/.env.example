# ============================================
#   PORTAINER — Environment Variables
#   Docs: https://docs.portainer.io
# ============================================

# --- Porte esposte ---
# Porta HTTP (redirect a HTTPS)
PORTAINER_PORT_HTTP=8000
# Porta HTTPS (interfaccia web principale)
PORTAINER_PORT_HTTPS=9443

# --- Dati persistenti ---
# Percorso locale per i dati di Portainer
PORTAINER_DATA=./data

# --- Socket Proxy — Permessi API Docker ---
# Abilita l'accesso in lettura ai container
SOCKET_PROXY_CONTAINERS=1
# Abilita l'accesso ai servizi (Docker Swarm)
SOCKET_PROXY_SERVICES=1
# Abilita l'accesso ai task (Docker Swarm)
SOCKET_PROXY_TASKS=1
# Abilita l'accesso alle immagini
SOCKET_PROXY_IMAGES=1
# Abilita l'accesso ai volumi
SOCKET_PROXY_VOLUMES=1
# Abilita l'accesso alle reti
SOCKET_PROXY_NETWORKS=1

# --- Socket Proxy — Permessi avanzati ---
# Permette di eseguire comandi nei container (exec)
# ⚠️  Impostare a 0 se non necessario (rischio sicurezza)
SOCKET_PROXY_EXEC=1
# Permette richieste POST (modifica stato dei container)
# ⚠️  Impostare a 0 per un proxy in sola lettura
SOCKET_PROXY_POST=1

# --- Socket Proxy — Info di sistema ---
SOCKET_PROXY_INFO=1
SOCKET_PROXY_PING=1
SOCKET_PROXY_VERSION=1
