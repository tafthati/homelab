# ============================================
#   GRAFANA — Environment Variables
#   Docs: https://grafana.com/docs/grafana/latest/setup-grafana/configure-grafana
# ============================================

# --- Sicurezza amministratore ---
# ⚠️  Valido SOLO alla prima installazione — ignorato se la password è già stata cambiata via web
# ⚠️  Cambia subito la password di default dopo il primo avvio!
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=your_secure_admin_password_here

# Disabilita la registrazione autonoma di nuovi utenti
# ⚠️  CRITICO — tenere sempre a false in ambienti non pubblici
GF_USERS_ALLOW_SIGN_UP=false

# --- Autenticazione ---
# Disabilita l'accesso anonimo al servizio
# ⚠️  CRITICO — tenere sempre a false
GF_AUTH_ANONYMOUS_ENABLED=false

# Nasconde la versione di Grafana dalla login page
# Consigliato per ridurre la superficie di attacco (security through obscurity)
GF_SECURITY_DISABLE_GRAVATAR=true
GF_ANALYTICS_REPORTING_ENABLED=false
GF_ANALYTICS_CHECK_FOR_UPDATES=false

# Mantiene il form di login visibile (necessario senza SSO/OAuth)
GF_AUTH_DISABLE_LOGIN_FORM=false

# --- Server e Reverse Proxy (predisposizione) ---
# ⚠️  Scommenta e configura quando aggiungi un reverse proxy davanti a Grafana
# GF_SERVER_DOMAIN=grafana.tuodominio.com
# GF_SERVER_ROOT_URL=https://grafana.tuodominio.com/
# GF_SERVER_SERVE_FROM_SUB_PATH=false
