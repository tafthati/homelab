# ============================================
#   UPTIME KUMA — Environment Variables
#   Docs: https://github.com/louislam/uptime-kuma/wiki
# ============================================

# --- Porte esposte ---
# Porta su cui esporre l'interfaccia web di Uptime Kuma
KUMA_PORT=3003

# --- Dati persistenti ---
# Percorso locale per database e configurazione di Kuma
KUMA_DATA=./data

# --- Socket Proxy — Permessi API Docker ---
# Abilita il monitoraggio dello stato dei container
SOCKET_PROXY_CONTAINERS=1
# Abilita le informazioni generali sul daemon Docker
SOCKET_PROXY_INFO=1

# --- Socket Proxy — Permessi avanzati ---
# Permette richieste POST (modifica stato dei container)
# ⚠️  Mantenere a 0 — Kuma è solo monitoraggio, non ha bisogno di scrivere
SOCKET_PROXY_POST=0
