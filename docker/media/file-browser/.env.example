# ============================================
#   FILEBROWSER — Environment Variables
#   Docs: https://filebrowser.org/configuration
# ============================================

# --- Porte esposte ---
# Porta su cui esporre l'interfaccia web di FileBrowser
FILEBROWSER_PORT=8082

# --- Permessi filesystem ---
# UID e GID dell'utente sul sistema host (per i permessi sui volumi)
# Verifica i tuoi con: id $(whoami)
PUID=1000
PGID=1000

# --- Percorsi ---
# Cartella radice esposta da FileBrowser
MEDIA_PATH=/percorso/della/cartella

# Percorso del database interno di FileBrowser
DB_FILE=./filebrowser.db

# Percorso del file di configurazione
SETTINGS_FILE=./settings.json

# --- Configurazione server ---
# Timezone del server
TZ=Europe/Rome
