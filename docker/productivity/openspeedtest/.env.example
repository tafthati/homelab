# ============================================
#   OPENSPEEDTEST — Environment Variables
#   Docs: https://github.com/openspeedtest/Speed-Test
# ============================================

# --- Porte esposte ---
# Porta HTTP su cui esporre il servizio
OPENSPEEDTEST_PORT_HTTP=2080
# Porta HTTPS su cui esporre il servizio
OPENSPEEDTEST_PORT_HTTPS=2443

# --- Let's Encrypt (SSL automatico) ---
# true  = abilita SSL pubblico (richiede DOMAIN_NAME e USER_EMAIL)
# false = HTTP semplice, consigliato per uso locale/LAN
ENABLE_LETSENCRYPT=false

# Dominio pubblico per Let's Encrypt
# ⚠️  Necessario solo se ENABLE_LETSENCRYPT=true
# Esempio: speedtest.tuodominio.com
DOMAIN_NAME=your.domain.com

# Email per la registrazione del certificato Let's Encrypt
# ⚠️  Necessario solo se ENABLE_LETSENCRYPT=true
USER_EMAIL=your@email.com

# --- Configurazione server ---
# Timezone del server
# Esempio: Europe/Rome
TZ=Europe/Rome
