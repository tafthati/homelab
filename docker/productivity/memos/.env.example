# ============================================
#   MEMOS — Environment Variables
#   Docs: https://www.usememos.com/docs
# ============================================

# --- Porte esposte ---
# Porta su cui esporre l'interfaccia web di Memos
MEMOS_PORT=5230

# --- Dati persistenti ---
# Percorso locale per note e database di Memos
# Esempio: /home/tuousername/.memos
MEMOS_DATA=/home/YOUR_USERNAME/.memos

# --- Configurazione server ---
# Timezone del server
# Esempio: Europe/Rome
TZ=Europe/Rome
