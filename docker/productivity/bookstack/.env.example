# ============================================
#   BOOKSTACK — Environment Variables
#   Docs: https://www.bookstackapp.com/docs/admin/configuration
# ============================================

# --- Applicazione ---
# URL base su cui BookStack è raggiungibile
# Esempio: http://tuo_ip:6875 oppure https://wiki.tuodominio.com
APP_URL=http://tuo_ip:6875

# Chiave segreta dell'applicazione (usata per cifrare sessioni e token)
APP_KEY=base64:your_generated_app_key_here

# --- Database ---
# ⚠️  Usa password lunghe e casuali — genera con: openssl rand -base64 24
DB_USER=bookstack
DB_PASSWORD=your_secure_db_password_here
DB_NAME=bookstackapp
DB_ROOT_PASSWORD=your_secure_root_password_here

# --- Configurazione server ---
# Timezone del server
TZ=Europe/Rome

# UID e GID dell'utente sul sistema host (per i permessi sui volumi)
# Verifica i tuoi con: id $(whoami)
PUID=1000
PGID=1000
